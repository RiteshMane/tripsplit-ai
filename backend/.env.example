# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (docker-compose default) - use this when running via docker-compose
MONGO_URI=mongodb://mongo:27017/tripsplit
# If running backend locally (not in docker) against the dockerized mongo, use:
# MONGO_URI=mongodb://localhost:27017/tripsplit

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Gemini AI (https://aistudio.google.com/app/apikey - free tier)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
